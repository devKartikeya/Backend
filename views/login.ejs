<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login | Lumina Travels</title>
    <link rel="stylesheet" href="/stylesheets/login.css" />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="background-circles">
      <div class="circle"></div>
      <div class="circle"></div>
    </div>

    <div class="login-container">
      <form class="login-form" id="form" action="/log-in" method="POST">
        <h2>Welcome Back</h2>
        <p>Enter your details to continue your journey.</p>

        <div class="input-group">
          <label for="email">Email</label>
          <input type="email" id="email"name="email" required />
          <div class="error" id="email-error"></div>
        </div>

        <div class="input-group">
          <label for="password">Password</label>
          <input type="password" id="password" name="password" required />
          <div class="error" id="password-error"></div>
        </div>

        <div class="options">
          <label><input type="checkbox" /> Remember me</label>
          <a href="#">Forgot Password?</a>
        </div>

        <button type="submit" class="login-btn">Sign In</button>

        <div class="divider">
          <span>or login with</span>
        </div>

        <div class="social-login">
          <button type="button" class="social-btn">Google</button>
          <button type="button" class="social-btn">Apple</button>
        </div>

        <p class="signup-link">
          Don't have an account? <a href="/">Sign up for free</a>
        </p>
      </form>
    </div>
    <script type="module" src="/javascripts/login.js"></script>
  </body>
</html>
