<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Nexus | Streamline Your Workflow</title>
    <link rel="stylesheet" href="/stylesheets/home.css" />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <nav class="navbar">
      <div class="logo">NEXUS</div>
      <ul class="nav-links">
        <li><a href="">Features</a></li>
        <li><a href="">Pricing</a></li>
        <li><a href="">About</a></li>
        <li><a href="">Contact Us</a></li>
        <li><a href="" class="nav-btn">Get Started</a></li>
      </ul>
    </nav>

    <header class="hero">
      <div class="hero-content">
        <span class="badge">Version 2.0 is here</span>
        <h1>
          Focus on what <br /><span class="gradient-text">truly matters.</span>
        </h1>
        <p>
          Nexus helps teams organize, track, and conquer projects in one
          beautiful workspace. Stop juggling apps and start shipping faster.
        </p>
        <div class="hero-btns">
          <a href="" class="btn-primary">Start for Free</a>
          <a href="" class="btn-secondary">Watch Demo</a>
        </div>
      </div>
      <div class="hero-visual">
        <div class="glass-card">
          <div class="card-header">
            <span class="dot red"></span><span class="dot yellow"></span
            ><span class="dot green"></span>
          </div>
          <div class="card-body">
            <div class="skeleton line-long"></div>
            <div class="skeleton line-med"></div>
            <div class="skeleton line-short"></div>
          </div>
        </div>
      </div>
    </header>

    <section class="features">
      <div class="feature-card">
        <div class="icon">⚡</div>
        <h3>Lightning Fast</h3>
        <p>Built for speed with real-time syncing across all devices.</p>
      </div>
      <div class="feature-card">
        <div class="icon">🛡️</div>
        <h3>Secure by Default</h3>
        <p>Enterprise-grade encryption for all your sensitive data.</p>
      </div>
      <div class="feature-card">
        <div class="icon">🎨</div>
        <h3>Beautiful UI</h3>
        <p>A workspace you'll actually enjoy looking at every day.</p>
      </div>
    </section>
  </body>
</html>
